void mousePressed(int coinCreditInt){
  int clicked = 0;
  for(int i=0; i<clicked; i++){
    coinCreditInt++;
    if(coinCreditInt>clicked){
      println("more coins than clicks");
    }
  }
}

void mouseReleased(int coinCreditInt){
  boolean released = false;
  
  if(released==true){
    coinCreditInt+=5;
  }
}
